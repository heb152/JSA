}

function exportCSV(){
  const rows = parseReport(document.getElementById('rawOutput').textContent || fullRawOutput);
  if(!rows.length){ alert('No table data to export. Run analysis first.'); return; }
  const headers = ['Job Step','Hazard','Likelihood','Impact','Preventive Measures'];
  const csvRows = [headers.join(',')];
  rows.forEach(cols => {
    const escaped = cols.map(c => '"' + (c||'').replace(/"/g,'""') + '"');
    while(escaped.length < 5) escaped.push('""');
    csvRows.push(escaped.slice(0,5).join(','));
  });
  const blob=new Blob([csvRows.join('\n')],{type:'text/csv'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='JSA_Report.csv';
  a.click();
}

