let currentProvider = 'groq';

let fullRawOutput = '';

// ── INIT ─────────────────────────────────────────────────
function selectProvider(p) {
  currentProvider = p;
  document.querySelectorAll('.provider-btn').forEach(b => b.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
  updateModels();
  document.getElementById('apiLink').href = PROVIDERS[p].apiLink;
  document.getElementById('apiKey').placeholder = `Paste your ${PROVIDERS[p].name} API key...`;
  // Show groq limit badge only for Groq
  document.getElementById('groqLimitBadge').style.display = p === 'groq' ? 'block' : 'none';
}

function updateModels() {
  const sel = document.getElementById('modelSelect');
  sel.innerHTML = '';
  PROVIDERS[currentProvider].models.forEach(m => {
    const opt = document.createElement('option');
    opt.value = m.id;
    opt.textContent = m.name;
    sel.appendChild(opt);
  });
}

function setTask(t) { document.getElementById('taskInput').value = t; }

function showTab(name) {
  const names = ['table','summary','raw'];
  document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', names[i]===name));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
}

function setAgent(n, status) {
  const card = document.getElementById('agent-'+n);
  card.classList.remove('active','done');
  const st = card.querySelector('.agent-status');
  if (status==='active') { card.classList.add('active'); st.textContent='Running...'; }
  else if (status==='done') { card.classList.add('done'); st.textContent='Done ✓'; }
  else { st.textContent='Waiting...'; }
}

function resetAgents() {
  for(let i=1;i<=6;i++) setAgent(i,'waiting');
  document.getElementById('feedbackBadge').style.display='none';
}


// ── API CALLS ────────────────────────────────────────────
function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

async function sleepWithCountdown(ms, nextAgentNum) {
  const card = document.getElementById('agent-'+nextAgentNum);
  const st = card ? card.querySelector('.agent-status') : null;
  const secs = Math.ceil(ms/1000);
  for (let i=secs; i>0; i--) {
    if (st) st.textContent = `Starting in ${i}s...`;
    await sleep(1000);
  }
  if (st) st.textContent = 'Waiting...';
}

async function callAPI(systemPrompt, userMessage) {
  const apiKey = document.getElementById('apiKey').value.trim();
  const model = document.getElementById('modelSelect').value;
  const provider = PROVIDERS[currentProvider];

  if (provider.type === 'openai-compat') {
    const res = await fetch(provider.baseURL, {
      method: 'POST',
      headers: { 'Content-Type':'application/json', 'Authorization':'Bearer '+apiKey },
      body: JSON.stringify({ model, temperature:0.1, max_tokens:4096,
        messages:[{role:'system',content:systemPrompt},{role:'user',content:userMessage}]
      })
    });
    if (!res.ok) { const e=await res.json(); throw new Error(e.error?.message||'API Error'); }
    const d = await res.json();
    return d.choices[0].message.content;

  } else if (provider.type === 'gemini') {
    const url = `${provider.baseURL}/${model}:generateContent?key=${apiKey}`;
    const res = await fetch(url, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        contents:[{parts:[{text: systemPrompt+'\n\n'+userMessage}]}],
        generationConfig:{temperature:0.1,maxOutputTokens:4096}
      })
    });
    if (!res.ok) { const e=await res.json(); throw new Error(e.error?.message||'Gemini API Error'); }
    const d = await res.json();
    return d.candidates[0].content.parts[0].text;

  } else if (provider.type === 'anthropic') {
    const res = await fetch(provider.baseURL, {
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
      body: JSON.stringify({ model, max_tokens:4096,
        system: systemPrompt,
        messages:[{role:'user',content:userMessage}]
      })
    });
    if (!res.ok) { const e=await res.json(); throw new Error(e.error?.message||'Anthropic API Error'); }
    const d = await res.json();
    return d.content[0].text;
  }
}


// ── AGENTS ───────────────────────────────────────────────
async function agentProjectManager(job) {
  return await callAPI(
    `You are a highly skilled project manager with expertise in construction projects. Break down the given construction task into clear, detailed implementation steps focusing on the execution phase. Format as a numbered list.`,
    `Break down this construction task into steps: ${job}`
  );
}
async function agentRiskIdentifier(steps) {
  return await callAPI(
    `You are an expert construction safety inspector. Identify all potential hazards for each step. Be specific and thorough.`,
    `Identify hazards for each step:\n${steps}`
  );
}
async function agentRiskAssessor(hazards, feedback=null) {
  const sys = `You are a construction risk assessment expert. Evaluate each hazard using:
LIKELIHOOD: P1(<1%) P2(1-5%) P3(5-25%) P4(25-50%) P5(50-75%) P6(>75%)
IMPACT: C1(insignificant) C2(minor) C3(moderate) C4(significant) C5(major/1 fatality) C6(catastrophic)
For each hazard provide likelihood, impact, and justification.${feedback?' Incorporate feedback provided.':''}`;
  return await callAPI(sys, `Assess hazards:\n${hazards}${feedback?'\n\nFeedback:\n'+feedback:''}`);
}
async function agentRiskManager(assessments) {
  return await callAPI(
    `You are a senior risk manager. Review assessments. Respond "APPROVED" if accurate, or "REVISION NEEDED" with specific feedback. Do NOT reassign scores yourself.`,
    `Review:\n${assessments}`
  );
}
async function agentSafetyManager(assessments) {
  return await callAPI(
    `You are a construction safety manager. Develop preventive measures for moderate and high-risk hazards (P3C3+). Include: preventive measures, PPE, engineering/admin controls.`,
    `Develop controls for:\n${assessments}`
  );
}
async function agentReporter(job, steps, hazards, assessments, controls) {
  return await callAPI(
    `You are a technical report writer for construction safety. Compile a JSA report with:
1. A table — format rows as: STEP | HAZARD | P# | C# | MEASURES (pipe-delimited)
2. Sections: ### Findings, ### Recommendations, ### Conclusion, ### Next Steps
Only include moderate and high-risk hazards.`,
    `JSA for: ${job}\nSteps: ${steps}\nHazards: ${hazards}\nAssessments: ${assessments}\nControls: ${controls}`
  );
}

// ── MAIN RUNNER ──────────────────────────────────────────
async function runJSA() {
  const apiKey = document.getElementById('apiKey').value.trim();
  const task = document.getElementById('taskInput').value.trim();
  if (!apiKey) { showError('Please enter your API Key.'); return; }
  if (!task) { showError('Please enter a construction task.'); return; }

  hideError();
  fullRawOutput = '';
  // Only delay for Groq due to rate limiting
  const delay = currentProvider === 'groq' ? 30000 : 500;

  document.getElementById('runBtn').disabled = true;
  document.getElementById('runBtn').textContent = '⏳ Running Analysis...';
  document.getElementById('progressSection').style.display = 'block';
  document.getElementById('reportSection').style.display = 'none';
  resetAgents();

  try {
    setAgent(1,'active');
    const steps = await agentProjectManager(task);
    fullRawOutput += '🔵 AGENT 1 — PROJECT MANAGER\n'+steps+'\n\n';
    setAgent(1,'done');

    await sleepWithCountdown(delay,2);
    setAgent(2,'active');
    const hazards = await agentRiskIdentifier(steps);
    fullRawOutput += '🟡 AGENT 2 — RISK IDENTIFIER\n'+hazards+'\n\n';
    setAgent(2,'done');

    await sleepWithCountdown(delay,3);
    setAgent(3,'active');
    let assessments = await agentRiskAssessor(hazards);
    fullRawOutput += '🟠 AGENT 3 — RISK ASSESSOR (Pass 1)\n'+assessments+'\n\n';
    setAgent(3,'done');

    await sleepWithCountdown(delay,4);
    setAgent(4,'active');
    let review = await agentRiskManager(assessments);
    fullRawOutput += '🔴 AGENT 4 — RISK MANAGER\n'+review+'\n\n';
    setAgent(4,'done');

    if (review.includes('REVISION NEEDED')) {
      document.getElementById('feedbackBadge').style.display='flex';
      await sleepWithCountdown(delay,3);
      setAgent(3,'active');
      assessments = await agentRiskAssessor(hazards,review);
      fullRawOutput += '🔄 AGENT 3 — REVISED\n'+assessments+'\n\n';
      setAgent(3,'done');

      await sleepWithCountdown(delay,4);
      setAgent(4,'active');
      review = await agentRiskManager(assessments);
      fullRawOutput += '🔄 AGENT 4 — RE-REVIEW\n'+review+'\n\n';
      setAgent(4,'done');
    }

    await sleepWithCountdown(delay,5);
    setAgent(5,'active');
    const controls = await agentSafetyManager(assessments);
    fullRawOutput += '🟢 AGENT 5 — SAFETY MANAGER\n'+controls+'\n\n';
    setAgent(5,'done');

    await sleepWithCountdown(delay,6);
    setAgent(6,'active');
    const report = await agentReporter(task,steps,hazards,assessments,controls);
    fullRawOutput += '🟣 AGENT 6 — REPORTER\n'+report+'\n\n';
    setAgent(6,'done');

    renderTable(parseReport(report));
    renderSummary(report);
    document.getElementById('rawOutput').textContent = fullRawOutput;
    document.getElementById('reportSection').style.display = 'block';
    document.getElementById('reportSection').scrollIntoView({behavior:'smooth'});

  } catch(err) { showError('Error: '+err.message); }

  document.getElementById('runBtn').disabled = false;
  document.getElementById('runBtn').textContent = '▶ Run Job Safety Analysis';
}

// ── RENDER ───────────────────────────────────────────────
function parseReport(text) {
  const rows=[];
  for (const line of text.split('\n')) {
    if (!line.includes('|')) continue;
    const cols=line.split('|').map(c=>c.trim()).filter(c=>c);
    if (cols.length<4) continue;
    if (cols[0].toLowerCase().includes('job step')||cols[0].startsWith('-')||cols[0]==='---') continue;
    rows.push(cols);
  }
  return rows;
}

function getCBadge(c) {
  const n=parseInt(c.replace(/[^0-9]/g,''));
  if(n<=2) return 'badge-c-low';
  if(n<=4) return 'badge-c-mid';
  return 'badge-c-high';
}

function renderTable(rows) {
  const tbody=document.getElementById('reportTableBody');
  tbody.innerHTML='';
  if(!rows.length){
    tbody.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:30px">No table parsed — check Raw Output tab</td></tr>';
    return;
  }
  rows.forEach(cols=>{
    const tr=document.createElement('tr');
    const l=cols[2]||'', im=cols[3]||'';
    tr.innerHTML=`<td>${cols[0]||''}</td><td>${cols[1]||''}</td>
      <td><span class="badge badge-p">${l}</span></td>
      <td><span class="badge ${getCBadge(im)}">${im}</span></td>
      <td>${cols.slice(4).join(' ')||''}</td>`;
    tbody.appendChild(tr);
  });
}

function renderSummary(text) {
  const sections=['Findings','Recommendations','Conclusion','Next Steps'];
  const container=document.getElementById('summaryContent');
  container.innerHTML='';
  sections.forEach(sec=>{
    const rx=new RegExp(`###?\\s*${sec}([\\s\\S]*?)(?=###?\\s*(${sections.join('|')})|$)`,'i');
    const m=text.match(rx);
    if(m){
      const card=document.createElement('div');
      card.className='report-card';
      card.innerHTML=`<h4>${sec}</h4><p>${m[1].replace(/\*\*/g,'').trim().replace(/\n/g,'<br>')}</p>`;
      container.appendChild(card);
    }
  });
  if(!container.innerHTML){
    container.innerHTML=`<div class="report-card"><h4>Report</h4><p style="white-space:pre-wrap">${text}</p></div>`;
  }
}

function showError(msg){
  const b=document.getElementById('errorBox');
  b.textContent='⚠️ '+msg; b.style.display='block';
}
function hideError(){ document.getElementById('errorBox').style.display='none'; }

