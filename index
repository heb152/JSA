<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JSA Multiagent System — University of Pittsburgh</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
  --pitt-blue: #003594;
  --pitt-gold: #FFB81C;
  --pitt-gold-light: #FFC94D;
  --pitt-blue-light: #1a4a9e;
  --bg: #ffffff;
  --surface: #f8f9fc;
  --surface2: #eef1f7;
  --border: #dde2ef;
  --text: #1a1f36;
  --text-muted: #6b7280;
  --success: #16a34a;
  --warning: #d97706;
  --danger: #dc2626;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* ── HEADER ── */
header {
  background: var(--pitt-blue);
  padding: 0 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  box-shadow: 0 2px 8px rgba(0,53,148,0.15);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.pitt-logo {
  width: 38px; height: 38px;
  background: var(--pitt-gold);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; font-weight: 800;
  color: var(--pitt-blue);
  font-family: 'Inter', sans-serif;
  letter-spacing: -1px;
}

.header-title { color: white; }
.header-title h1 { font-size: 17px; font-weight: 700; letter-spacing: -0.3px; }
.header-title p { font-size: 11px; color: rgba(255,255,255,0.6); margin-top: 1px; }

.header-badge {
  background: rgba(255,184,28,0.15);
  border: 1px solid rgba(255,184,28,0.3);
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 12px;
  color: var(--pitt-gold);
  font-weight: 500;
}

/* ── GOLD BAR ── */
.gold-bar {
  height: 4px;
  background: var(--pitt-gold);
}

/* ── CONTAINER ── */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 36px 24px;
}

/* ── SECTION CARD ── */
.card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px 28px;
  margin-bottom: 20px;
  box-shadow: 0 1px 4px rgba(0,53,148,0.06);
}

.card-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--pitt-blue);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.card-title::before {
  content: '';
  display: block;
  width: 3px; height: 16px;
  background: var(--pitt-gold);
  border-radius: 2px;
}

/* ── PROVIDER SELECTOR ── */
.provider-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-bottom: 16px;
}

@media (max-width: 640px) {
  .provider-grid { grid-template-columns: repeat(2, 1fr); }
}

.provider-btn {
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 12px 8px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--surface);
  font-family: 'Inter', sans-serif;
}

.provider-btn:hover { border-color: var(--pitt-blue); }

.provider-btn.selected {
  border-color: var(--pitt-blue);
  background: rgba(0,53,148,0.05);
}

.provider-icon { font-size: 22px; margin-bottom: 5px; }
.provider-name { font-size: 12px; font-weight: 600; color: var(--text); }
.provider-tag {
  font-size: 10px;
  color: var(--success);
  background: rgba(22,163,74,0.1);
  border-radius: 4px;
  padding: 1px 5px;
  margin-top: 3px;
  display: inline-block;
}
.provider-tag.paid { color: var(--warning); background: rgba(217,119,6,0.1); }

/* ── MODEL SELECT ── */
.model-row {
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}

.model-row label {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  white-space: nowrap;
}

select {
  flex: 1;
  min-width: 200px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--text);
  outline: none;
  cursor: pointer;
  transition: border-color 0.2s;
}

select:focus { border-color: var(--pitt-blue); }

/* ── API KEY ── */
.api-row {
  display: flex;
  gap: 12px;
  align-items: center;
  margin-top: 14px;
  flex-wrap: wrap;
}

.api-row label {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  white-space: nowrap;
}

.api-row input {
  flex: 1;
  min-width: 200px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 14px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s;
}

.api-row input:focus { border-color: var(--pitt-blue); }

.api-link {
  font-size: 12px;
  color: var(--pitt-blue);
  text-decoration: none;
  white-space: nowrap;
}
.api-link:hover { text-decoration: underline; }

/* ── GROQ LIMIT BADGE ── */
.groq-limit-badge {
  display: none;
  margin-top: 12px;
  background: rgba(0,53,148,0.05);
  border: 1px solid rgba(0,53,148,0.15);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.6;
}
.groq-limit-badge strong { color: var(--pitt-blue); }

/* ── TASK INPUT ── */
textarea {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 16px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  color: var(--text);
  resize: vertical;
  min-height: 90px;
  outline: none;
  transition: border-color 0.2s;
  line-height: 1.6;
}
textarea:focus { border-color: var(--pitt-blue); }



/* ── QUICK TASKS ── */
.quick-tasks {
  margin-top: 14px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}
.quick-tasks span { font-size: 12px; color: var(--text-muted); }
.quick-btn {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 5px 12px;
  font-size: 12px;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.15s;
  font-family: 'Inter', sans-serif;
}
.quick-btn:hover {
  border-color: var(--pitt-blue);
  color: var(--pitt-blue);
  background: rgba(0,53,148,0.05);
}

/* ── RUN BUTTON ── */
.run-btn {
  margin-top: 18px;
  width: 100%;
  background: var(--pitt-blue);
  color: white;
  border: none;
  border-radius: 10px;
  padding: 14px;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.run-btn:hover { background: var(--pitt-blue-light); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,53,148,0.2); }
.run-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

/* ── PROGRESS ── */
.progress-section {
  display: none;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px 28px;
  margin-bottom: 20px;
  box-shadow: 0 1px 4px rgba(0,53,148,0.06);
}

.agents-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
@media (max-width: 600px) { .agents-grid { grid-template-columns: repeat(2, 1fr); } }

.agent-card {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: all 0.3s;
}
.agent-card.active { border-color: var(--pitt-gold); background: rgba(255,184,28,0.05); }
.agent-card.done { border-color: var(--success); background: rgba(22,163,74,0.04); }

.agent-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--border);
  flex-shrink: 0;
  transition: all 0.3s;
}
.agent-card.active .agent-dot { background: var(--pitt-gold); box-shadow: 0 0 8px var(--pitt-gold); animation: pulse 1s infinite; }
.agent-card.done .agent-dot { background: var(--success); }

@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

.agent-name { font-size: 12px; font-weight: 600; color: var(--text); }
.agent-status { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.agent-card.active .agent-status { color: var(--warning); }
.agent-card.done .agent-status { color: var(--success); }

.feedback-badge {
  display: none;
  background: rgba(217,119,6,0.08);
  border: 1px solid rgba(217,119,6,0.25);
  border-radius: 8px;
  padding: 10px 16px;
  margin-top: 14px;
  font-size: 13px;
  color: var(--warning);
  align-items: center;
  gap: 8px;
}

/* ── ERROR ── */
.error-box {
  display: none;
  background: rgba(220,38,38,0.06);
  border: 1px solid rgba(220,38,38,0.2);
  border-radius: 10px;
  padding: 14px 18px;
  font-size: 13px;
  color: var(--danger);
  margin-bottom: 18px;
}

/* ── REPORT ── */
.report-section { display: none; }

.report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
  flex-wrap: wrap;
  gap: 10px;
}
.report-header h2 { font-size: 18px; font-weight: 700; color: var(--pitt-blue); }

.export-group {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.export-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 8px 16px;
  font-size: 13px;
  color: var(--text);
  cursor: pointer;
  transition: all 0.15s;
  font-family: 'Inter', sans-serif;
  font-weight: 500;
}
.export-btn:hover { border-color: var(--pitt-blue); color: var(--pitt-blue); }
.export-btn-primary {
  background: var(--pitt-blue);
  color: white;
  border-color: var(--pitt-blue);
}
.export-btn-primary:hover { background: var(--pitt-blue-light); color: white; }

/* ── TABS ── */
.tabs {
  display: flex;
  gap: 4px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 4px;
  margin-bottom: 18px;
}
.tab {
  flex: 1;
  padding: 9px;
  text-align: center;
  font-size: 13px;
  font-weight: 500;
  border-radius: 7px;
  cursor: pointer;
  transition: all 0.2s;
  color: var(--text-muted);
  border: none;
  background: transparent;
  font-family: 'Inter', sans-serif;
}
.tab.active { background: var(--pitt-blue); color: white; }

.tab-content { display: none; }
.tab-content.active { display: block; }

/* ── TABLE ── */
.table-wrapper { overflow-x: auto; border-radius: 12px; border: 1px solid var(--border); }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead tr { background: var(--pitt-blue); }
th {
  padding: 12px 16px;
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: rgba(255,255,255,0.85);
  border-bottom: none;
  white-space: nowrap;
}
td {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
  line-height: 1.5;
  color: var(--text);
}
tr:last-child td { border-bottom: none; }
tr:nth-child(even) td { background: var(--surface); }
tr:hover td { background: rgba(0,53,148,0.03); }

.badge {
  display: inline-block;
  padding: 3px 8px;
  border-radius: 5px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 600;
}
.badge-p { background: rgba(0,53,148,0.1); color: var(--pitt-blue); }
.badge-c-low { background: rgba(22,163,74,0.12); color: var(--success); }
.badge-c-mid { background: rgba(217,119,6,0.12); color: var(--warning); }
.badge-c-high { background: rgba(220,38,38,0.12); color: var(--danger); }

/* ── SUMMARY CARDS ── */
.report-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 4px solid var(--pitt-gold);
  border-radius: 10px;
  padding: 20px 22px;
  margin-bottom: 12px;
}
.report-card h4 {
  font-size: 12px;
  font-weight: 700;
  color: var(--pitt-blue);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 8px;
}
.report-card p { font-size: 14px; line-height: 1.7; color: var(--text-muted); }

/* ── RAW OUTPUT ── */
.raw-output {
  background: var(--pitt-blue);
  border-radius: 10px;
  padding: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  line-height: 1.8;
  color: rgba(255,255,255,0.85);
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 500px;
  overflow-y: auto;
}

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--border);
  padding: 16px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text-muted);
}
footer strong { color: var(--pitt-blue); }

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--surface); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
</style>
</head>
<body>

<header>
  <div class="header-left">
    <div class="pitt-logo">Pitt</div>
    <div class="header-title">
      <h1>JSA Multiagent System</h1>
      <p>Construction Job Safety Analysis · 6 Specialized Agents</p>
    </div>
  </div>
  <span class="header-badge">Research Tool</span>
</header>
<div class="gold-bar"></div>

<div class="container">

  <!-- PROVIDER & MODEL -->
  <div class="card">
    <div class="card-title">AI Provider & Model</div>

    <div class="provider-grid">
      <div class="provider-btn selected" onclick="selectProvider('groq')">
        <div class="provider-icon">⚡</div>
        <div class="provider-name">Groq</div>
        <div class="provider-tag">Free</div>
      </div>
      <div class="provider-btn" onclick="selectProvider('openai')">
        <div class="provider-icon">🤖</div>
        <div class="provider-name">OpenAI</div>
        <div class="provider-tag paid">Paid</div>
      </div>
      <div class="provider-btn" onclick="selectProvider('gemini')">
        <div class="provider-icon">✨</div>
        <div class="provider-name">Gemini</div>
        <div class="provider-tag">Free Tier</div>
      </div>
      <div class="provider-btn" onclick="selectProvider('anthropic')">
        <div class="provider-icon">🧠</div>
        <div class="provider-name">Anthropic</div>
        <div class="provider-tag paid">Paid</div>
      </div>
    </div>

    <div class="model-row">
      <label>Model:</label>
      <select id="modelSelect"></select>
    </div>

    <div class="api-row">
      <label>🔑 API Key:</label>
      <input type="password" id="apiKey" placeholder="Paste your API key here..." value="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" />
      <a class="api-link" id="apiLink" href="#" target="_blank">Get API Key →</a>
    </div>
    <div class="groq-limit-badge" id="groqLimitBadge">
      ⚡ Groq Free Tier · Limit: <strong>12,000 tokens/min</strong> · ~<strong>29 analyses/day</strong> · Delay between agents: <strong>30s</strong>
    </div>
  </div>

  <!-- TASK INPUT -->
  <div class="card">
    <div class="card-title">Construction Task</div>
    <textarea id="taskInput" placeholder="Describe the construction task — e.g. Tunnel lining and support system installation"></textarea>

    <div class="quick-tasks">
      <span>Quick select:</span>
      <button class="quick-btn" onclick="setTask('Tunnel lining and support system installation')">Tunnel Lining</button>
      <button class="quick-btn" onclick="setTask('Scaffolding erection and dismantling')">Scaffolding</button>
      <button class="quick-btn" onclick="setTask('Concrete pouring for high-rise foundation')">Concrete Pouring</button>
      <button class="quick-btn" onclick="setTask('Electrical wiring installation in commercial building')">Electrical Wiring</button>
      <button class="quick-btn" onclick="setTask('Steel structural frame erection')">Steel Erection</button>
      <button class="quick-btn" onclick="setTask('Excavation and trenching for underground utilities')">Excavation</button>
    </div>



    <button class="run-btn" id="runBtn" onclick="runJSA()">
      ▶ Run Job Safety Analysis
    </button>
  </div>

  <!-- ERROR -->
  <div class="error-box" id="errorBox"></div>

  <!-- PROGRESS -->
  <div class="progress-section" id="progressSection">
    <div class="card-title">Agent Progress</div>
    <div class="agents-grid">
      <div class="agent-card" id="agent-1">
        <div class="agent-dot"></div>
        <div>
          <div class="agent-name">Project Manager</div>
          <div class="agent-status">Waiting...</div>
        </div>
      </div>
      <div class="agent-card" id="agent-2">
        <div class="agent-dot"></div>
        <div>
          <div class="agent-name">Risk Identifier</div>
          <div class="agent-status">Waiting...</div>
        </div>
      </div>
      <div class="agent-card" id="agent-3">
        <div class="agent-dot"></div>
        <div>
          <div class="agent-name">Risk Assessor</div>
          <div class="agent-status">Waiting...</div>
        </div>
      </div>
      <div class="agent-card" id="agent-4">
        <div class="agent-dot"></div>
        <div>
          <div class="agent-name">Risk Manager</div>
          <div class="agent-status">Waiting...</div>
        </div>
      </div>
      <div class="agent-card" id="agent-5">
        <div class="agent-dot"></div>
        <div>
          <div class="agent-name">Safety Manager</div>
          <div class="agent-status">Waiting...</div>
        </div>
      </div>
      <div class="agent-card" id="agent-6">
        <div class="agent-dot"></div>
        <div>
          <div class="agent-name">Reporter</div>
          <div class="agent-status">Waiting...</div>
        </div>
      </div>
    </div>
    <div class="feedback-badge" id="feedbackBadge">
      🔄 Feedback loop triggered — Risk Assessor is revising assessments...
    </div>
  </div>

  <!-- REPORT -->
  <div class="report-section" id="reportSection">
    <div class="report-header">
      <h2>📋 JSA Report</h2>
      <div class="export-group">
        <button class="export-btn" onclick="exportTXT()">⬇ TXT</button>
        <button class="export-btn" onclick="exportCSV()">⬇ CSV</button>
        <button class="export-btn export-btn-primary" onclick="exportHTML()">⬇ HTML Report</button>
      </div>
    </div>
    <div class="tabs">
      <button class="tab active" onclick="showTab('table')">Risk Table</button>
      <button class="tab" onclick="showTab('summary')">Summary</button>
      <button class="tab" onclick="showTab('raw')">Raw Output</button>
    </div>
    <div class="tab-content active" id="tab-table">
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Job Step</th><th>Hazard</th><th>Likelihood</th><th>Impact</th><th>Preventive Measures</th>
            </tr>
          </thead>
          <tbody id="reportTableBody"></tbody>
        </table>
      </div>
    </div>
    <div class="tab-content" id="tab-summary">
      <div id="summaryContent"></div>
    </div>
    <div class="tab-content" id="tab-raw">
      <div class="raw-output" id="rawOutput"></div>
    </div>
  </div>

</div>

<footer>
  <span><strong>University of Pittsburgh</strong> · Civil Engineering · JSA Multiagent Research</span>
</footer>

<script>
// ── PROVIDERS & MODELS ───────────────────────────────────
const PROVIDERS = {
  groq: {
    name: 'Groq',
    baseURL: 'https://api.groq.com/openai/v1/chat/completions',
    apiLink: 'https://console.groq.com/keys',
    type: 'openai-compat',
    delay: 20000,
    models: [
      { id: 'llama-3.3-70b-versatile', name: 'Llama 3.3 70B (Recommended)' },
      { id: 'llama-3.1-8b-instant', name: 'Llama 3.1 8B (Fast)' },
      { id: 'gemma2-9b-it', name: 'Gemma 2 9B' },
      { id: 'mixtral-8x7b-32768', name: 'Mixtral 8x7B' },
    ]
  },
  openai: {
    name: 'OpenAI',
    baseURL: 'https://api.openai.com/v1/chat/completions',
    apiLink: 'https://platform.openai.com/api-keys',
    type: 'openai-compat',
    delay: 2000,
    models: [
      { id: 'gpt-4o-mini', name: 'GPT-4o Mini (Recommended)' },
      { id: 'gpt-4o', name: 'GPT-4o' },
